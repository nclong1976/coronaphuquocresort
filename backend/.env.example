DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/casino_db"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"
PORT=4000
NODE_ENV=development

# CORS — khi set, Express chỉ cho các origin này (bắt buộc cho production).
# Để trống / không khai báo: dev cho phép mọi origin (origin: true).
# Production ví dụ:
# CORS_ORIGINS="https://coronaphuquocresort.com,https://www.coronaphuquocresort.com"
# Dev LAN:
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
